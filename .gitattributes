# Normalize text files by default.
* text=auto

# Keep documentation and source/config files in LF to avoid CRLF conversion warnings.
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf

# Keep shell scripts in LF.
*.sh text eol=lf

# Keep Windows scripts in CRLF for native execution compatibility.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
